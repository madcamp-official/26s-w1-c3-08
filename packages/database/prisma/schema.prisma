generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
  BLOCKED
  MODERATION_FAILED
  CANCELED
}

enum MessageArrivalMode {
  FIXED
  RANDOM_WINDOW
}

enum MessageTheme {
  LAVENDER
  MOSS
  SUNSET
  MIDNIGHT
  PAPER
}

enum RecipientType {
  SELF
  FRIEND
  OTHER
}

enum RecipientDeliveryStatus {
  WAITING
  SENT
  FAILED
  CANCELED
}

enum EmotionTag {
  THANKS
  CHEER
  CELEBRATION
  COMFORT
  LONGING
  LOVE
  CUSTOM
}

enum ModerationAttemptStatus {
  APPROVED
  BLOCKED
  FAILED
}

enum AttachmentOcrStatus {
  SKIPPED
  EXTRACTED
  FAILED
}

enum NotificationChannel {
  IN_APP
  KAKAO_ALIMTALK
  SMS
  EMAIL
}

enum NotificationEventType {
  MESSAGE_SENT
  ARRIVAL_HINT
  REPLY_RECEIVED
  COLLECTION_DELIVERED
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
  EXPIRED
}

enum MessageReplyStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum UserContactType {
  EMAIL
  PHONE
}

enum UserContactVerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum PhoneVerificationAttemptStatus {
  REQUESTED
  SENT
  BLOCKED
  SEND_FAILED
}

enum PhoneVerificationLockScope {
  IP
  CONTACT
}

enum CommunicationBlockDirection {
  SEND_TO
  RECEIVE_FROM
}

enum CommunicationBlockTargetType {
  USER
  EMAIL
  PHONE
}

enum MessageCollectionStatus {
  ACTIVE
  DELIVERED
  CANCELED
}

enum MessageCollectionSubmissionStatus {
  VISIBLE
  BLOCKED
  HIDDEN
  DELETED
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  kakaoId         String    @unique @db.VarChar(64)
  nickname        String    @db.VarChar(80)
  email           String?   @db.VarChar(255)
  friendCode      String    @unique @db.VarChar(20)
  profileImageUrl String?   @db.VarChar(2048)
  onboardingNote  String?   @db.Text
  signupPhoneVerificationRequiredAt  DateTime? @db.Timestamptz(3)
  signupPhoneVerificationCompletedAt DateTime? @db.Timestamptz(3)
  lastLoginAt     DateTime? @db.Timestamptz(3)
  suspendedAt     DateTime? @db.Timestamptz(3)
  suspensionReason String?  @db.Text
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime? @db.Timestamptz(3)

  sentMessages        Message[]            @relation("MessageSender")
  receivedRecipients  MessageRecipient[]   @relation("RecipientUser")
  claimedAccessTokens MessageAccessToken[] @relation("AccessTokenClaimedBy")
  sentFriendRequests  FriendRequest[]      @relation("FriendRequestRequester")
  receivedFriendRequests FriendRequest[]   @relation("FriendRequestAddressee")
  friendshipsAsA      Friendship[]         @relation("FriendshipUserA")
  friendshipsAsB      Friendship[]         @relation("FriendshipUserB")
  createdFriendships  Friendship[]         @relation("FriendshipCreatedBy")
  friendInviteLinks   FriendInviteLink[]   @relation("FriendInviteInviter")
  submittedReports    MessageReport[]      @relation("ReportReporter")
  contacts            UserContact[]
  messageCollections  MessageCollection[]     @relation("MessageCollectionOwner")
  targetNotifications NotificationLog[]        @relation("NotificationTargetUser")
  authoredReplies     MessageReply[]           @relation("ReplyAuthor")
  communicationBlocksOwned CommunicationBlock[] @relation("CommunicationBlockOwner")
  communicationBlocksTargeted CommunicationBlock[] @relation("CommunicationBlockTargetUser")

  @@index([email])
  @@index([createdAt])
}

model Message {
  id                       String        @id @default(uuid()) @db.Uuid
  senderId                 String        @db.Uuid
  senderContactId          String?       @db.Uuid
  senderContactSnapshot    Json?
  senderDisplayName        String?       @db.VarChar(80)
  title                    String        @db.VarChar(120)
  content                  String        @db.Text
  emotionTag               EmotionTag?
  customEmotionTag         String?       @db.VarChar(40)
  scheduledAt              DateTime      @db.Timestamptz(3)
  arrivalMode              MessageArrivalMode @default(FIXED)
  arrivalWindowStartAt     DateTime?     @db.Timestamptz(3)
  arrivalWindowEndAt       DateTime?     @db.Timestamptz(3)
  hintAt                   DateTime?     @db.Timestamptz(3)
  hintSentAt               DateTime?     @db.Timestamptz(3)
  theme                    MessageTheme  @default(LAVENDER)
  isReplyEnabled           Boolean       @default(true)
  sentAt                   DateTime?     @db.Timestamptz(3)
  canceledAt               DateTime?     @db.Timestamptz(3)
  failedAt                 DateTime?     @db.Timestamptz(3)
  failureReason            String?       @db.Text
  senderDeletedAt          DateTime?     @db.Timestamptz(3)
  isSenderHidden           Boolean       @default(false)
  isDateHidden             Boolean       @default(false)
  status                   MessageStatus @default(PENDING)
  moderationAttemptCount   Int           @default(0)
  moderationLastCheckedAt  DateTime?     @db.Timestamptz(3)
  moderationNextRetryAt    DateTime?     @db.Timestamptz(3)
  moderationFailureReason  String?       @db.Text
  moderationFeedback       String?       @db.Text
  moderationBlockedCategories Json?
  createdAt                DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime      @updatedAt @db.Timestamptz(3)

  sender         User                 @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderContact  UserContact?         @relation("MessageSenderContact", fields: [senderContactId], references: [id], onDelete: SetNull)
  recipients     MessageRecipient[]
  attachments    MessageAttachment[]
  replies        MessageReply[]
  reports        MessageReport[]
  moderationLogs ModerationLog[]

  @@index([senderId, createdAt])
  @@index([senderId, senderDeletedAt])
  @@index([senderContactId])
  @@index([status, scheduledAt])
  @@index([status, hintAt])
  @@index([status, moderationNextRetryAt])
  @@index([createdAt])
}

model UserContact {
  id                 String          @id @default(uuid()) @db.Uuid
  userId             String          @db.Uuid
  type               UserContactType
  value              String          @db.VarChar(255)
  contactHash        String          @db.Char(64)
  label              String?         @db.VarChar(80)
  isPrimary          Boolean         @default(false)
  verifiedAt         DateTime?       @db.Timestamptz(3)
  verificationSource String?         @db.VarChar(40)
  deletedAt          DateTime?       @db.Timestamptz(3)
  createdAt          DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime        @updatedAt @db.Timestamptz(3)

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifications UserContactVerification[]
  sentMessages  Message[]                 @relation("MessageSenderContact")

  @@unique([type, contactHash])
  @@index([userId, type, deletedAt])
  @@index([userId, isPrimary])
  @@index([verifiedAt])
}

model UserContactVerification {
  id            String                        @id @default(uuid()) @db.Uuid
  userContactId String                        @db.Uuid
  codeHash      String                        @db.Char(64)
  status        UserContactVerificationStatus @default(PENDING)
  expiresAt     DateTime                      @db.Timestamptz(3)
  consumedAt    DateTime?                     @db.Timestamptz(3)
  attemptCount  Int                           @default(0)
  createdAt     DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                      @updatedAt @db.Timestamptz(3)

  contact UserContact @relation(fields: [userContactId], references: [id], onDelete: Cascade)

  @@index([userContactId, status, expiresAt])
  @@index([createdAt])
}

model PhoneVerificationAttempt {
  id          String                         @id @default(uuid()) @db.Uuid
  userId      String?                        @db.Uuid
  ipHash      String                         @db.Char(64)
  contactHash String                         @db.Char(64)
  status      PhoneVerificationAttemptStatus
  reason      String?                        @db.VarChar(120)
  createdAt   DateTime                       @default(now()) @db.Timestamptz(3)

  @@index([ipHash, createdAt])
  @@index([contactHash, createdAt])
  @@index([status, createdAt])
}

model PhoneVerificationLock {
  id          String                     @id @default(uuid()) @db.Uuid
  scope       PhoneVerificationLockScope
  scopeHash   String                     @db.Char(64)
  reason      String                     @db.VarChar(120)
  lockedUntil DateTime                   @db.Timestamptz(3)
  createdAt   DateTime                   @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime                   @updatedAt @db.Timestamptz(3)

  @@unique([scope, scopeHash])
  @@index([lockedUntil])
}

model PhoneNumberLookupCache {
  provider    String   @db.VarChar(40)
  contactHash String   @db.Char(64)
  valid       Boolean
  lineType    String   @db.VarChar(40)
  carrierName String?  @db.VarChar(120)
  allowed     Boolean
  reason      String?  @db.VarChar(120)
  checkedAt   DateTime @default(now()) @db.Timestamptz(3)
  expiresAt   DateTime @db.Timestamptz(3)

  @@id([provider, contactHash])
  @@index([expiresAt])
}

model MessageRecipient {
  id             String                  @id @default(uuid()) @db.Uuid
  messageId      String                  @db.Uuid
  receiverUserId String?                 @db.Uuid
  receiverType   RecipientType
  receiverName   String?                 @db.VarChar(80)
  receiverEmail  String?                 @db.VarChar(255)
  receiverPhone  String?                 @db.VarChar(32)
  receiverInfo   Json?
  deliveryStatus RecipientDeliveryStatus @default(WAITING)
  deliveredAt    DateTime?               @db.Timestamptz(3)
  readAt         DateTime?               @db.Timestamptz(3)
  receiverDeletedAt DateTime?            @db.Timestamptz(3)
  receiverArchivedAt DateTime?           @db.Timestamptz(3)
  createdAt      DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime                @updatedAt @db.Timestamptz(3)

  message       Message              @relation(fields: [messageId], references: [id], onDelete: Cascade)
  receiverUser  User?                @relation("RecipientUser", fields: [receiverUserId], references: [id], onDelete: SetNull)
  accessTokens  MessageAccessToken[]
  notifications NotificationLog[]
  replies       MessageReply[]
  reports       MessageReport[]

  @@index([messageId])
  @@index([receiverUserId, readAt])
  @@index([receiverUserId, receiverDeletedAt])
  @@index([receiverUserId, receiverArchivedAt])
  @@index([deliveryStatus])
  @@index([receiverEmail])
  @@index([receiverPhone])
}

model MessageReport {
  id                 String       @id @default(uuid()) @db.Uuid
  messageId          String       @db.Uuid
  messageRecipientId String?      @db.Uuid
  reporterUserId     String?      @db.Uuid
  reason             String       @db.VarChar(80)
  details            String?      @db.Text
  status             ReportStatus @default(PENDING)
  reviewedAt         DateTime?    @db.Timestamptz(3)
  reviewNote         String?      @db.Text
  createdAt          DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime     @updatedAt @db.Timestamptz(3)

  message   Message           @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient MessageRecipient? @relation(fields: [messageRecipientId], references: [id], onDelete: SetNull)
  reporter  User?             @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([messageRecipientId])
  @@index([reporterUserId])
  @@index([status, createdAt])
}

model MessageAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String   @db.Uuid
  publicUrl    String   @db.VarChar(2048)
  storageKey   String   @db.VarChar(512)
  originalName String?  @db.VarChar(255)
  mimeType     String   @db.VarChar(80)
  sizeBytes    Int
  ocrStatus    AttachmentOcrStatus @default(SKIPPED)
  ocrText      String?  @db.Text
  ocrConfidence Float?
  ocrError     String?  @db.Text
  ocrCheckedAt DateTime? @db.Timestamptz(3)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([createdAt])
}

model MessageReply {
  id                 String             @id @default(uuid()) @db.Uuid
  messageId          String             @db.Uuid
  messageRecipientId String             @db.Uuid
  authorUserId       String?            @db.Uuid
  content            String             @db.Text
  senderDisplayName  String?            @db.VarChar(80)
  isAnonymous        Boolean            @default(true)
  status             MessageReplyStatus @default(VISIBLE)
  moderationInputHash String?           @db.Char(64)
  moderationCategories Json?
  senderReadAt       DateTime?          @db.Timestamptz(3)
  senderDeletedAt    DateTime?          @db.Timestamptz(3)
  authorDeletedAt    DateTime?          @db.Timestamptz(3)
  notifiedAt         DateTime?          @db.Timestamptz(3)
  hiddenAt           DateTime?          @db.Timestamptz(3)
  hiddenReason       String?            @db.Text
  createdAt          DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(3)

  message   Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient MessageRecipient @relation(fields: [messageRecipientId], references: [id], onDelete: Cascade)
  author    User?            @relation("ReplyAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  notifications NotificationLog[] @relation("ReplyNotifications")

  @@index([messageId, createdAt])
  @@index([messageRecipientId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([authorDeletedAt, createdAt])
  @@index([senderDeletedAt, createdAt])
  @@index([senderReadAt, createdAt])
  @@index([status, createdAt])
}

model MessageAccessToken {
  id                 String    @id @default(uuid()) @db.Uuid
  messageRecipientId String    @db.Uuid
  tokenHash          String    @unique @db.Char(64)
  tokenPreview       String?   @db.VarChar(12)
  expiresAt          DateTime? @db.Timestamptz(3)
  firstOpenedAt      DateTime? @db.Timestamptz(3)
  lastOpenedAt       DateTime? @db.Timestamptz(3)
  openCount          Int       @default(0)
  linkedUserId       String?   @db.Uuid
  linkedAt           DateTime? @db.Timestamptz(3)
  revokedAt          DateTime? @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(3)

  recipient  MessageRecipient @relation(fields: [messageRecipientId], references: [id], onDelete: Cascade)
  linkedUser User?            @relation("AccessTokenClaimedBy", fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@index([messageRecipientId])
  @@index([linkedUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model ModerationLog {
  id             String                  @id @default(uuid()) @db.Uuid
  messageId      String                  @db.Uuid
  attemptNo      Int
  provider       String                  @default("openai") @db.VarChar(40)
  model          String                  @db.VarChar(80)
  status         ModerationAttemptStatus
  inputHash      String?                 @db.Char(64)
  categories     Json?
  categoryScores Json?
  feedback       String?                 @db.Text
  errorCode      String?                 @db.VarChar(120)
  errorMessage   String?                 @db.Text
  checkedAt      DateTime                @default(now()) @db.Timestamptz(3)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, attemptNo])
  @@index([status, checkedAt])
  @@index([messageId, checkedAt])
}

model NotificationLog {
  id                 String                @id @default(uuid()) @db.Uuid
  messageRecipientId String?               @db.Uuid
  targetUserId       String?               @db.Uuid
  messageReplyId     String?               @db.Uuid
  messageCollectionId String?              @db.Uuid
  eventType          NotificationEventType @default(MESSAGE_SENT)
  channel            NotificationChannel
  status             NotificationStatus    @default(PENDING)
  provider           String?               @db.VarChar(80)
  idempotencyKey     String                @unique @db.VarChar(160)
  attemptCount       Int                   @default(0)
  providerMessageId  String?               @db.VarChar(160)
  payload            Json?
  errorCode          String?               @db.VarChar(120)
  errorMessage       String?               @db.Text
  scheduledAt        DateTime?             @db.Timestamptz(3)
  nextRetryAt        DateTime?             @db.Timestamptz(3)
  attemptedAt        DateTime?             @db.Timestamptz(3)
  sentAt             DateTime?             @db.Timestamptz(3)
  readAt             DateTime?             @db.Timestamptz(3)
  createdAt          DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @db.Timestamptz(3)

  recipient MessageRecipient? @relation(fields: [messageRecipientId], references: [id], onDelete: Cascade)
  targetUser User?            @relation("NotificationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  reply      MessageReply?    @relation("ReplyNotifications", fields: [messageReplyId], references: [id], onDelete: Cascade)
  collection MessageCollection? @relation("CollectionNotifications", fields: [messageCollectionId], references: [id], onDelete: Cascade)

  @@index([messageRecipientId, channel])
  @@index([targetUserId, eventType, createdAt])
  @@index([targetUserId, readAt, createdAt])
  @@index([messageReplyId])
  @@index([messageCollectionId])
  @@index([status, scheduledAt])
  @@index([status, nextRetryAt])
  @@index([eventType, createdAt])
}

model ContactSuppression {
  id                       String              @id @default(uuid()) @db.Uuid
  channel                  NotificationChannel
  contactHash              String              @db.Char(64)
  sourceMessageRecipientId String?             @db.Uuid
  reason                   String?             @db.VarChar(120)
  createdAt                DateTime            @default(now()) @db.Timestamptz(3)

  @@unique([channel, contactHash])
  @@index([createdAt])
}

model CommunicationBlock {
  id                String                         @id @default(uuid()) @db.Uuid
  ownerUserId       String                         @db.Uuid
  direction         CommunicationBlockDirection
  targetType        CommunicationBlockTargetType
  targetUserId      String?                        @db.Uuid
  targetContactHash String?                        @db.Char(64)
  targetMaskedValue String?                        @db.VarChar(255)
  targetLabel       String?                        @db.VarChar(80)
  targetDisplayName String?                        @db.VarChar(80)
  createdAt         DateTime                       @default(now()) @db.Timestamptz(3)

  owner      User  @relation("CommunicationBlockOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  targetUser User? @relation("CommunicationBlockTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, direction, targetType, targetUserId], map: "CommunicationBlock_owner_user_target_key")
  @@unique([ownerUserId, direction, targetType, targetContactHash], map: "CommunicationBlock_owner_contact_target_key")
  @@index([ownerUserId, direction, createdAt], map: "CommunicationBlock_owner_direction_created_idx")
  @@index([targetUserId, direction], map: "CommunicationBlock_target_user_direction_idx")
  @@index([targetContactHash, direction, targetType], map: "CommunicationBlock_target_contact_direction_idx")
}

model FriendRequest {
  id          String              @id @default(uuid()) @db.Uuid
  requesterId String              @db.Uuid
  addresseeId String              @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  message     String?             @db.VarChar(120)
  expiresAt   DateTime            @db.Timestamptz(3)
  respondedAt DateTime?           @db.Timestamptz(3)
  createdAt   DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime            @updatedAt @db.Timestamptz(3)

  requester User @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([expiresAt])
}

model FriendInviteLink {
  id           String    @id @default(uuid()) @db.Uuid
  inviterId    String    @db.Uuid
  tokenHash    String    @unique @db.Char(64)
  tokenPreview String?   @db.VarChar(12)
  expiresAt    DateTime  @db.Timestamptz(3)
  maxClaims    Int       @default(1)
  claimCount   Int       @default(0)
  revokedAt    DateTime? @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)

  inviter User @relation("FriendInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model MessageCollection {
  id           String                  @id @default(uuid()) @db.Uuid
  ownerId      String                  @db.Uuid
  tokenHash    String                  @unique @db.Char(64)
  tokenPreview String?                 @db.VarChar(12)
  title        String                  @db.VarChar(120)
  description  String?                 @db.Text
  scheduledAt  DateTime                @db.Timestamptz(3)
  status       MessageCollectionStatus @default(ACTIVE)
  deliveredAt  DateTime?               @db.Timestamptz(3)
  canceledAt   DateTime?               @db.Timestamptz(3)
  createdAt    DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime                @updatedAt @db.Timestamptz(3)

  owner         User                          @relation("MessageCollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  submissions   MessageCollectionSubmission[]
  notifications NotificationLog[]             @relation("CollectionNotifications")

  @@index([ownerId, status, scheduledAt])
  @@index([status, scheduledAt])
  @@index([scheduledAt])
}

model MessageCollectionSubmission {
  id                  String                            @id @default(uuid()) @db.Uuid
  collectionId        String                            @db.Uuid
  senderDisplayName   String?                           @db.VarChar(80)
  content             String                            @db.Text
  status              MessageCollectionSubmissionStatus @default(VISIBLE)
  moderationInputHash String?                           @db.Char(64)
  moderationCategories Json?
  moderationFeedback  String?                           @db.Text
  ipHash              String                            @db.Char(64)
  deliveredAt         DateTime?                         @db.Timestamptz(3)
  ownerReadAt         DateTime?                         @db.Timestamptz(3)
  hiddenAt            DateTime?                         @db.Timestamptz(3)
  hiddenReason        String?                           @db.Text
  createdAt           DateTime                          @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                          @updatedAt @db.Timestamptz(3)

  collection MessageCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, status, createdAt])
  @@index([collectionId, ipHash, createdAt])
  @@index([status, createdAt])
  @@index([ownerReadAt, createdAt])
}

model DailyLine {
  id          String   @id @default(uuid()) @db.Uuid
  text        String   @db.Text
  poemTitle   String   @db.VarChar(120)
  poet        String   @db.VarChar(80)
  sourceNote  String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  selections DailyLineSelection[]

  @@index([isActive, sortOrder])
}

model DailyLineSelection {
  date        String   @id @db.VarChar(10)
  dailyLineId String   @db.Uuid
  selectedAt  DateTime @default(now()) @db.Timestamptz(3)

  dailyLine DailyLine @relation(fields: [dailyLineId], references: [id], onDelete: Restrict)

  @@index([dailyLineId])
  @@index([selectedAt])
}

model Friendship {
  id          String    @id @default(uuid()) @db.Uuid
  userAId     String    @db.Uuid
  userBId     String    @db.Uuid
  createdById String    @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  userA     User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdBy User @relation("FriendshipCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, deletedAt])
  @@index([userBId, deletedAt])
  @@index([createdById])
}
