{
  "name": "@maeari/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm run copy-standalone-assets",
    "copy-standalone-assets": "mkdir -p .next/standalone/apps/web/.next && rm -rf .next/standalone/apps/web/.next/static .next/standalone/apps/web/public && cp -R .next/static .next/standalone/apps/web/.next/static && if [ -d public ]; then cp -R public .next/standalone/apps/web/public; fi",
    "start": "next start",
    "start:standalone": "node .next/standalone/apps/web/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@maeari/shared": "workspace:*",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
